# Copy to .env and adjust for local use. docker-compose.yml falls back to these
# same defaults when .env is absent, so this file is documentation, not a secret.

POSTGRES_USER=surveillance
POSTGRES_PASSWORD=surveillance
POSTGRES_DB=surveillance

# Signs operator JWTs (docs/DECISIONS.md ADR-0010). Replace with a long random
# value for anything beyond local dev, e.g. `openssl rand -hex 32`.
JWT_SECRET_KEY=dev-only-change-me-to-a-random-32-byte-value

# Retention/GC (docs/DECISIONS.md ADR-0011): identities/tracks older than this many
# days are deleted, along with their frame crops. GC runs on this interval.
RETENTION_DAYS=90
RETENTION_GC_INTERVAL_SECONDS=86400
