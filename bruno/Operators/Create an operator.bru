meta {
  name: Create an operator
  type: http
  seq: 1
}

post {
  url: {{base_url}}/operators
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "bruno-contract-test-operator",
    "password": "a-strong-password"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("new_operator_id", res.body.id);
  }
}

assert {
  res.status: eq 201
}
