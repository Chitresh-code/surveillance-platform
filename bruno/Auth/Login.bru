meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "{{operator_username}}",
    "password": "{{operator_password}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("access_token", res.body.access_token);
  }
}
